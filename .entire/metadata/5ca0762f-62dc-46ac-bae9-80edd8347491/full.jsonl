{"parentUuid":"39e0cef8-00d6-4a6a-aa3b-7930467e286f","isSidechain":false,"message":{"id":"0dfee62b-0976-45fe-a1e6-ec437bf61a58","type":"message","role":"assistant","model":"deepseek-v4-pro","content":[{"type":"tool_use","id":"call_00_8SlfK8x5oytpLkYtRX686110","name":"Write","input":{"file_path":"e:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code\\pretrain.py","content":"import torch\nimport torch.nn as nn\nimport torch.optim as optim\nfrom torch.optim.lr_scheduler import CosineAnnealingLR\nimport os\nfrom tqdm import tqdm\n\nfrom model import SimCLR\nfrom loss import NTXentLoss\nfrom data_utils import get_cifar10_dataloader\n\n\ndef pretrain(config):\n    \"\"\"SimCLR 预训练主函数\n\n    Args:\n        config: dict，包含所有超参数\n\n    关键设计要点：\n    1. 每条数据给两个增广视图 x1, x2\n    2. 分别过 encoder + projection head → z1, z2\n    3. 把 z1, z2 交替拼接成 (2N, D) → 计算 NT-Xent loss\n    4. 只在 encoder 输出后做 L2 归一化，不需要额外 normalization\n    \"\"\"\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n    print(f\"Device: {device}\")\n\n    # ---- 数据加载 ----\n    train_loader = get_cifar10_dataloader(\n        data_dir=config['data_dir'],\n        batch_size=config['batch_size'],\n        num_workers=config.get('num_workers', 0),\n        train_size=config.get('train_size', None),\n    )\n    print(f\"Dataset: CIFAR-10, batches: {len(train_loader)}, \"\n          f\"batch_size: {config['batch_size']}\")\n\n    # ---- 模型 ----\n    model = SimCLR(\n        encoder_name=config.get('encoder', 'resnet18'),\n        proj_hidden_dim=config.get('proj_hidden_dim', 512),\n        proj_out_dim=config.get('proj_out_dim', 128),\n    ).to(device)\n    print(f\"Model: {config.get('encoder', 'resnet18')}, \"\n          f\"params: {sum(p.numel() for p in model.parameters()):,}\")\n\n    # ---- 优化器 & 学习率调度 ----\n    # SimCLR 论文用 LARS，小规模实验用 AdamW 更稳定\n    optimizer = optim.AdamW(\n        model.parameters(),\n        lr=config.get('lr', 1e-3),\n        weight_decay=config.get('weight_decay', 1e-4),\n    )\n    scheduler = CosineAnnealingLR(\n        optimizer,\n        T_max=config['epochs'],\n        eta_min=config.get('lr_min', 1e-5),\n    )\n\n    # ---- Loss ----\n    criterion = NTXentLoss(temperature=config.get('temperature', 0.5))\n\n    # ---- 训练循环 ----\n    best_loss = float('inf')\n    log_interval = config.get('log_interval', 50)\n\n    for epoch in range(1, config['epochs'] + 1):\n        model.train()\n        total_loss = 0.0\n\n        pbar = tqdm(train_loader, desc=f\"Epoch {epoch}/{config['epochs']}\")\n        for step, ((x1, x2), _) in enumerate(pbar):\n            # CIFAR10 dataset 返回 (data, label)，但 SimCLRTransform\n            # 把 data 变成了 (x1, x2) 元组，所以解包为 ((x1,x2), label)\n            x1 = x1.to(device)\n            x2 = x2.to(device)\n            N = x1.size(0)\n\n            # 关键：把两个增广视图交替拼接\n            # z = [img1_aug1, img1_aug2, img2_aug1, img2_aug2, ...]\n            z1 = model(x1)      # (N, D)\n            z2 = model(x2)      # (N, D)\n            z = torch.empty(2 * N, z1.size(1), device=device)\n            z[0::2] = z1        # 偶数位放 aug1\n            z[1::2] = z2        # 奇数位放 aug2\n\n            loss = criterion(z)\n\n            optimizer.zero_grad()\n            loss.backward()\n            optimizer.step()\n\n            total_loss += loss.item()\n            pbar.set_postfix(loss=f\"{loss.item():.4f}\")\n\n            if step % log_interval == 0 and step > 0:\n                avg = total_loss / (step + 1)\n                pbar.set_postfix(loss=f\"{loss.item():.4f}\", avg=f\"{avg:.4f}\")\n\n        scheduler.step()\n        avg_loss = total_loss / len(train_loader)\n        print(f\"Epoch {epoch:3d}/{config['epochs']}  \"\n              f\"loss={avg_loss:.4f}  lr={scheduler.get_last_lr()[0]:.2e}\")\n\n        # ---- 保存最佳模型 ----\n        if avg_loss < best_loss:\n            best_loss = avg_loss\n            save_path = os.path.join(config['save_dir'], 'simclr_best.pth')\n            torch.save({\n                'epoch': epoch,\n                'model_state_dict': model.state_dict(),\n                'optimizer_state_dict': optimizer.state_dict(),\n                'loss': avg_loss,\n                'config': config,\n            }, save_path)\n            print(f\"  → Best model saved to {save_path}\")\n\n    # ---- 保存最终模型 ----\n    final_path = os.path.join(config['save_dir'], 'simclr_final.pth')\n    torch.save({\n        'epoch': config['epochs'],\n        'model_state_dict': model.state_dict(),\n        'config': config,\n    }, final_path)\n    print(f\"\\nFinal model saved to {final_path}\")\n\n    return model\n\n\nif __name__ == '__main__':\n    config = {\n        'data_dir': '../data',\n        'save_dir': '../checkpoints',\n        'batch_size': 512,\n        'epochs': 100,\n        'encoder': 'resnet18',          # 'resnet18' 或 'cnn'\n        'proj_hidden_dim': 512,\n        'proj_out_dim': 128,\n        'temperature': 0.5,\n        'lr': 1e-3,\n        'lr_min': 1e-5,\n        'weight_decay': 1e-4,\n        'num_workers': 0,\n        # 'train_size': 5000,           # CPU 快速实验时取消注释\n        'log_interval': 50,\n    }\n\n    os.makedirs(config['save_dir'], exist_ok=True)\n    pretrain(config)\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":725,"cache_creation_input_tokens":0,"cache_read_input_tokens":32896,"output_tokens":1825,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"type":"assistant","uuid":"807a56e1-8e3b-488a-bc8a-451830ee912d","timestamp":"2026-06-27T11:35:30.770Z","userType":"external","entrypoint":"cli","cwd":"E:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code","sessionId":"5ca0762f-62dc-46ac-bae9-80edd8347491","version":"2.1.138","gitBranch":"master"}
