{"parentUuid":"b74e0e04-e89a-47be-bd6d-21ed8abe03e0","isSidechain":false,"promptId":"13b76d05-0035-499d-9731-834471f28820","type":"user","message":{"role":"user","content":[{"tool_use_id":"call_00_qYaGTpAuUAbogQnGFFrR8383","type":"tool_result","content":"1\timport torch\n2\timport torch.nn as nn\n3\timport torch.nn.functional as F\n4\t\n5\t\n6\t# ============================================================\n7\t# 1. 小型 CNN Encoder（最低要求，适合 CPU 训练）\n8\t# ============================================================\n9\tclass SmallCNN(nn.Module):\n10\t    \"\"\"轻量级 CNN，适合 CIFAR-10 32x32 输入 + CPU 快速实验\n11\t\n12\t    结构：\n13\t        Conv(3->64) -> ReLU -> MaxPool\n14\t        Conv(64->128) -> ReLU -> MaxPool\n15\t        Conv(128->256) -> ReLU -> MaxPool\n16\t        Global AvgPool -> 256-dim 特征向量\n17\t    \"\"\"\n18\t\n19\t    def __init__(self, in_channels=3, feat_dim=256):\n20\t        super().__init__()\n21\t        self.conv = nn.Sequential(\n22\t            nn.Conv2d(in_channels, 64, kernel_size=3, padding=1),\n23\t            nn.BatchNorm2d(64),\n24\t            nn.ReLU(inplace=True),\n25\t            nn.MaxPool2d(2),                   # 32 -> 16\n26\t\n27\t            nn.Conv2d(64, 128, kernel_size=3, padding=1),\n28\t            nn.BatchNorm2d(128),\n29\t            nn.ReLU(inplace=True),\n30\t            nn.MaxPool2d(2),                   # 16 -> 8\n31\t\n32\t            nn.Conv2d(128, 256, kernel_size=3, padding=1),\n33\t            nn.BatchNorm2d(256),\n34\t            nn.ReLU(inplace=True),\n35\t            nn.AdaptiveAvgPool2d((1, 1)),      # 8 -> 1\n36\t        )\n37\t        self.feat_dim = feat_dim\n38\t\n39\t    def forward(self, x):\n40\t        feat = self.conv(x)                    # (B, 256, 1, 1)\n41\t        feat = feat.view(feat.size(0), -1)     # (B, 256)\n42\t        return feat\n43\t\n44\t\n45\t# ============================================================\n46\t# 2. ResNet-18 Encoder（推荐要求，适配 CIFAR-10 32x32）\n47\t# ============================================================\n48\t\n49\tclass BasicBlock(nn.Module):\n50\t    \"\"\"ResNet 基本残差块：两个 3x3 卷积 + 跳跃连接\"\"\"\n51\t    expansion = 1\n52\t\n53\t    def __init__(self, in_planes, planes, stride=1):\n54\t        super().__init__()\n55\t        self.conv1 = nn.Conv2d(in_planes, planes, kernel_size=3,\n56\t                                stride=stride, padding=1, bias=False)\n57\t        self.bn1 = nn.BatchNorm2d(planes)\n58\t        self.conv2 = nn.Conv2d(planes, planes, kernel_size=3,\n59\t                                stride=1, padding=1, bias=False)\n60\t        self.bn2 = nn.BatchNorm2d(planes)\n61\t\n62\t        self.shortcut = nn.Sequential()\n63\t        if stride != 1 or in_planes != planes:\n64\t            self.shortcut = nn.Sequential(\n65\t                nn.Conv2d(in_planes, planes, kernel_size=1,\n66\t                          stride=stride, bias=False),\n67\t                nn.BatchNorm2d(planes),\n68\t            )\n69\t\n70\t    def forward(self, x):\n71\t        out = F.relu(self.bn1(self.conv1(x)))\n72\t        out = self.bn2(self.conv2(out))\n73\t        out += self.shortcut(x)\n74\t        out = F.relu(out)\n75\t        return out\n76\t\n77\t\n78\tclass ResNet18(nn.Module):\n79\t    \"\"\"简化 ResNet-18，适配 CIFAR-10 32x32 输入\n80\t\n81\t    相比标准 ImageNet ResNet-18 的修改：\n82\t    - 第 1 层: 3x3 conv (stride=1) 代替 7x7 conv (stride=2)  → 保留 32x32 分辨率\n83\t    - 去掉开头的 MaxPool → 防止过早丢失空间信息\n84\t    - 其余层与标准 ResNet-18 一致\n85\t    \"\"\"\n86\t\n87\t    def __init__(self, in_channels=3, feat_dim=512):\n88\t        super().__init__()\n89\t        self.in_planes = 64\n90\t        self.feat_dim = feat_dim\n91\t\n92\t        # CIFAR-10 适配的第 1 层 (3x3, stride=1, 不接 MaxPool)\n93\t        self.conv1 = nn.Conv2d(in_channels, 64, kernel_size=3,\n94\t                                stride=1, padding=1, bias=False)\n95\t        self.bn1 = nn.BatchNorm2d(64)\n96\t\n97\t        # 4 个 layer，channel 逐层翻倍\n98\t        self.layer1 = self._make_layer(64, 2, stride=1)    # 32x32\n99\t        self.layer2 = self._make_layer(128, 2, stride=2)   # 16x16\n100\t        self.layer3 = self._make_layer(256, 2, stride=2)   # 8x8\n101\t        self.layer4 = self._make_layer(512, 2, stride=2)   # 4x4\n102\t\n103\t        self.avgpool = nn.AdaptiveAvgPool2d((1, 1))\n104\t\n105\t    def _make_layer(self, planes, num_blocks, stride):\n106\t        layers = [BasicBlock(self.in_planes, planes, stride)]\n107\t        self.in_planes = planes\n108\t        for _ in range(1, num_blocks):\n109\t            layers.append(BasicBlock(self.in_planes, planes))\n110\t        return nn.Sequential(*layers)\n111\t\n112\t    def forward(self, x):\n113\t        out = F.relu(self.bn1(self.conv1(x)))\n114\t        out = self.layer1(out)\n115\t        out = self.layer2(out)\n116\t        out = self.layer3(out)\n117\t        out = self.layer4(out)\n118\t        out = self.avgpool(out)                  # (B, 512, 1, 1)\n119\t        out = out.view(out.size(0), -1)          # (B, 512)\n120\t        return out\n121\t\n122\t\n123\t# ============================================================\n124\t# 3. Projection Head（MLP: Linear -> ReLU -> Linear）\n125\t# ============================================================\n126\t\n127\tclass ProjectionHead(nn.Module):\n128\t    \"\"\"SimCLR 投影头：将 encoder 输出映射到对比学习空间\n129\t\n130\t    g(h) = W₂ · ReLU(W₁ · h)\n131\t\n132\t    论文发现 2 层 MLP 效果最优：\n133\t    - 恒等映射（不用 projection）→ 效果差\n134\t    - 线性投影 → 一般\n135\t    - 2 层 MLP → 最佳\n136\t    - 3 层 MLP → 没有进一步提升\n137\t    \"\"\"\n138\t\n139\t    def __init__(self, in_dim=512, hidden_dim=512, out_dim=128):\n140\t        super().__init__()\n141\t        self.net = nn.Sequential(\n142\t            nn.Linear(in_dim, hidden_dim),\n143\t            nn.ReLU(inplace=True),\n144\t            nn.Linear(hidden_dim, out_dim),\n145\t        )\n146\t\n147\t    def forward(self, x):\n148\t        return self.net(x)\n149\t\n150\t\n151\t# ============================================================\n152\t# 4. 完整 SimCLR 模型 = Encoder + ProjectionHead\n153\t# ============================================================\n154\t\n155\tclass SimCLR(nn.Module):\n156\t    \"\"\"SimCLR 模型：encoder + projection head\n157\t\n158\t    使用方法：\n159\t        model = SimCLR(encoder_name='resnet18')\n160\t\n161\t        # 预训练：encoder + projection head 一起用\n162\t        z1 = model(x1)   # projection 后的向量，用于对比 loss\n163\t        z2 = model(x2)\n164\t\n165\t        # Linear probe：冻结 encoder，只用 .encode()\n166\t        for p in model.encoder.parameters():\n167\t            p.requires_grad = False\n168\t        features = model.encode(images)  # encoder 原始输出\n169\t    \"\"\"\n170\t\n171\t    def __init__(self, encoder_name='resnet18', proj_hidden_dim=512, proj_out_dim=128):\n172\t        super().__init__()\n173\t\n174\t        # 选择 encoder\n175\t        if encoder_name == 'cnn':\n176\t            self.encoder = SmallCNN(in_channels=3, feat_dim=256)\n177\t            enc_dim = 256\n178\t        elif encoder_name == 'resnet18':\n179\t            self.encoder = ResNet18(in_channels=3, feat_dim=512)\n180\t            enc_dim = 512\n181\t        else:\n182\t            raise ValueError(f\"Unknown encoder: {encoder_name}. Use 'cnn' or 'resnet18'.\")\n183\t\n184\t        self.projection_head = ProjectionHead(\n185\t            in_dim=enc_dim,\n186\t            hidden_dim=proj_hidden_dim,\n187\t            out_dim=proj_out_dim,\n188\t        )\n189\t\n190\t    def forward(self, x):\n191\t        \"\"\"返回 L2 归一化后的投影向量（用于对比 loss）\"\"\"\n192\t        h = self.encoder(x)                 # encoder 特征\n193\t        z = self.projection_head(h)         # 投影\n194\t        z = F.normalize(z, dim=1)           # L2 归一化\n195\t        return z\n196\t\n197\t    def encode(self, x):\n198\t        \"\"\"返回 encoder 原始特征向量（用于 linear probe）\"\"\"\n199\t        return self.encoder(x)\n200\t\n201\t\n202\t# ============================================================\n203\t# 5. 快速测试\n204\t# ============================================================\n205\tif __name__ == '__main__':\n206\t    print(\"=\" * 60)\n207\t    print(\"测试 SmallCNN\")\n208\t    cnn = SmallCNN(in_channels=3, feat_dim=256)\n209\t    x = torch.randn(4, 3, 32, 32)\n210\t    out = cnn(x)\n211\t    print(f\"  输入: {x.shape}  ->  输出: {out.shape} (期望 [4, 256])\")\n212\t\n213\t    print(\"\\n\" + \"=\" * 60)\n214\t    print(\"测试 ResNet-18 (CIFAR-10 适配)\")\n215\t    resnet = ResNet18(in_channels=3, feat_dim=512)\n216\t    out = resnet(x)\n217\t    print(f\"  输入: {x.shape}  ->  输出: {out.shape} (期望 [4, 512])\")\n218\t\n219\t    print(\"\\n\" + \"=\" * 60)\n220\t    print(\"测试 ProjectionHead\")\n221\t    proj = ProjectionHead(in_dim=512, hidden_dim=512, out_dim=128)\n222\t    h = torch.randn(4, 512)\n223\t    z = proj(h)\n224\t    print(f\"  输入: {h.shape}  ->  输出: {z.shape} (期望 [4, 128])\")\n225\t\n226\t    print(\"\\n\" + \"=\" * 60)\n227\t    print(\"测试完整 SimCLR (resnet18)\")\n228\t    simclr = SimCLR(encoder_name='resnet18')\n229\t    x1 = torch.randn(4, 3, 32, 32)\n230\t    x2 = torch.randn(4, 3, 32, 32)\n231\t    z1 = simclr(x1)\n232\t    z2 = simclr(x2)\n233\t    feat = simclr.encode(x1)\n234\t    print(f\"  z1: {z1.shape}, z2: {z2.shape}, feat: {feat.shape}\")\n235\t    print(f\"  L2 norm of z1: {z1.norm(dim=1)[:4]} (应全为 1.0)\")\n236\t\n237\t    print(\"\\n\" + \"=\" * 60)\n238\t    print(\"测试完整 SimCLR (cnn)\")\n239\t    simclr_cnn = SimCLR(encoder_name='cnn')\n240\t    z1 = simclr_cnn(x1)\n241\t    feat = simclr_cnn.encode(x1)\n242\t    print(f\"  z1: {z1.shape}, feat: {feat.shape}\")\n243\t\n244\t    # 统计参数量\n245\t    print(\"\\n\" + \"=\" * 60)\n246\t    print(\"参数量统计:\")\n247\t    for name, model in [('SmallCNN', cnn), ('ResNet18', resnet)]:\n248\t        params = sum(p.numel() for p in model.parameters())\n249\t        print(f\"  {name}: {params:,} 参数\")\n250\t\n251\t    proj_params = sum(p.numel() for p in proj.parameters())\n252\t    print(f\"  ProjectionHead: {proj_params:,} 参数\")\n253\t    print(f\"  SimCLR (resnet18): {sum(p.numel() for p in simclr.parameters()):,} 参数\")\n254\t    print(f\"  SimCLR (cnn): {sum(p.numel() for p in simclr_cnn.parameters()):,} 参数\")\n255\t"}]},"uuid":"d3422dea-432a-4c3b-9ed8-de86b43e4335","timestamp":"2026-06-27T08:36:28.065Z","toolUseResult":{"type":"text","file":{"filePath":"e:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code\\model.py","content":"import torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\n\n# ============================================================\n# 1. 小型 CNN Encoder（最低要求，适合 CPU 训练）\n# ============================================================\nclass SmallCNN(nn.Module):\n    \"\"\"轻量级 CNN，适合 CIFAR-10 32x32 输入 + CPU 快速实验\n\n    结构：\n        Conv(3->64) -> ReLU -> MaxPool\n        Conv(64->128) -> ReLU -> MaxPool\n        Conv(128->256) -> ReLU -> MaxPool\n        Global AvgPool -> 256-dim 特征向量\n    \"\"\"\n\n    def __init__(self, in_channels=3, feat_dim=256):\n        super().__init__()\n        self.conv = nn.Sequential(\n            nn.Conv2d(in_channels, 64, kernel_size=3, padding=1),\n            nn.BatchNorm2d(64),\n            nn.ReLU(inplace=True),\n            nn.MaxPool2d(2),                   # 32 -> 16\n\n            nn.Conv2d(64, 128, kernel_size=3, padding=1),\n            nn.BatchNorm2d(128),\n            nn.ReLU(inplace=True),\n            nn.MaxPool2d(2),                   # 16 -> 8\n\n            nn.Conv2d(128, 256, kernel_size=3, padding=1),\n            nn.BatchNorm2d(256),\n            nn.ReLU(inplace=True),\n            nn.AdaptiveAvgPool2d((1, 1)),      # 8 -> 1\n        )\n        self.feat_dim = feat_dim\n\n    def forward(self, x):\n        feat = self.conv(x)                    # (B, 256, 1, 1)\n        feat = feat.view(feat.size(0), -1)     # (B, 256)\n        return feat\n\n\n# ============================================================\n# 2. ResNet-18 Encoder（推荐要求，适配 CIFAR-10 32x32）\n# ============================================================\n\nclass BasicBlock(nn.Module):\n    \"\"\"ResNet 基本残差块：两个 3x3 卷积 + 跳跃连接\"\"\"\n    expansion = 1\n\n    def __init__(self, in_planes, planes, stride=1):\n        super().__init__()\n        self.conv1 = nn.Conv2d(in_planes, planes, kernel_size=3,\n                                stride=stride, padding=1, bias=False)\n        self.bn1 = nn.BatchNorm2d(planes)\n        self.conv2 = nn.Conv2d(planes, planes, kernel_size=3,\n                                stride=1, padding=1, bias=False)\n        self.bn2 = nn.BatchNorm2d(planes)\n\n        self.shortcut = nn.Sequential()\n        if stride != 1 or in_planes != planes:\n            self.shortcut = nn.Sequential(\n                nn.Conv2d(in_planes, planes, kernel_size=1,\n                          stride=stride, bias=False),\n                nn.BatchNorm2d(planes),\n            )\n\n    def forward(self, x):\n        out = F.relu(self.bn1(self.conv1(x)))\n        out = self.bn2(self.conv2(out))\n        out += self.shortcut(x)\n        out = F.relu(out)\n        return out\n\n\nclass ResNet18(nn.Module):\n    \"\"\"简化 ResNet-18，适配 CIFAR-10 32x32 输入\n\n    相比标准 ImageNet ResNet-18 的修改：\n    - 第 1 层: 3x3 conv (stride=1) 代替 7x7 conv (stride=2)  → 保留 32x32 分辨率\n    - 去掉开头的 MaxPool → 防止过早丢失空间信息\n    - 其余层与标准 ResNet-18 一致\n    \"\"\"\n\n    def __init__(self, in_channels=3, feat_dim=512):\n        super().__init__()\n        self.in_planes = 64\n        self.feat_dim = feat_dim\n\n        # CIFAR-10 适配的第 1 层 (3x3, stride=1, 不接 MaxPool)\n        self.conv1 = nn.Conv2d(in_channels, 64, kernel_size=3,\n                                stride=1, padding=1, bias=False)\n        self.bn1 = nn.BatchNorm2d(64)\n\n        # 4 个 layer，channel 逐层翻倍\n        self.layer1 = self._make_layer(64, 2, stride=1)    # 32x32\n        self.layer2 = self._make_layer(128, 2, stride=2)   # 16x16\n        self.layer3 = self._make_layer(256, 2, stride=2)   # 8x8\n        self.layer4 = self._make_layer(512, 2, stride=2)   # 4x4\n\n        self.avgpool = nn.AdaptiveAvgPool2d((1, 1))\n\n    def _make_layer(self, planes, num_blocks, stride):\n        layers = [BasicBlock(self.in_planes, planes, stride)]\n        self.in_planes = planes\n        for _ in range(1, num_blocks):\n            layers.append(BasicBlock(self.in_planes, planes))\n        return nn.Sequential(*layers)\n\n    def forward(self, x):\n        out = F.relu(self.bn1(self.conv1(x)))\n        out = self.layer1(out)\n        out = self.layer2(out)\n        out = self.layer3(out)\n        out = self.layer4(out)\n        out = self.avgpool(out)                  # (B, 512, 1, 1)\n        out = out.view(out.size(0), -1)          # (B, 512)\n        return out\n\n\n# ============================================================\n# 3. Projection Head（MLP: Linear -> ReLU -> Linear）\n# ============================================================\n\nclass ProjectionHead(nn.Module):\n    \"\"\"SimCLR 投影头：将 encoder 输出映射到对比学习空间\n\n    g(h) = W₂ · ReLU(W₁ · h)\n\n    论文发现 2 层 MLP 效果最优：\n    - 恒等映射（不用 projection）→ 效果差\n    - 线性投影 → 一般\n    - 2 层 MLP → 最佳\n    - 3 层 MLP → 没有进一步提升\n    \"\"\"\n\n    def __init__(self, in_dim=512, hidden_dim=512, out_dim=128):\n        super().__init__()\n        self.net = nn.Sequential(\n            nn.Linear(in_dim, hidden_dim),\n            nn.ReLU(inplace=True),\n            nn.Linear(hidden_dim, out_dim),\n        )\n\n    def forward(self, x):\n        return self.net(x)\n\n\n# ============================================================\n# 4. 完整 SimCLR 模型 = Encoder + ProjectionHead\n# ============================================================\n\nclass SimCLR(nn.Module):\n    \"\"\"SimCLR 模型：encoder + projection head\n\n    使用方法：\n        model = SimCLR(encoder_name='resnet18')\n\n        # 预训练：encoder + projection head 一起用\n        z1 = model(x1)   # projection 后的向量，用于对比 loss\n        z2 = model(x2)\n\n        # Linear probe：冻结 encoder，只用 .encode()\n        for p in model.encoder.parameters():\n            p.requires_grad = False\n        features = model.encode(images)  # encoder 原始输出\n    \"\"\"\n\n    def __init__(self, encoder_name='resnet18', proj_hidden_dim=512, proj_out_dim=128):\n        super().__init__()\n\n        # 选择 encoder\n        if encoder_name == 'cnn':\n            self.encoder = SmallCNN(in_channels=3, feat_dim=256)\n            enc_dim = 256\n        elif encoder_name == 'resnet18':\n            self.encoder = ResNet18(in_channels=3, feat_dim=512)\n            enc_dim = 512\n        else:\n            raise ValueError(f\"Unknown encoder: {encoder_name}. Use 'cnn' or 'resnet18'.\")\n\n        self.projection_head = ProjectionHead(\n            in_dim=enc_dim,\n            hidden_dim=proj_hidden_dim,\n            out_dim=proj_out_dim,\n        )\n\n    def forward(self, x):\n        \"\"\"返回 L2 归一化后的投影向量（用于对比 loss）\"\"\"\n        h = self.encoder(x)                 # encoder 特征\n        z = self.projection_head(h)         # 投影\n        z = F.normalize(z, dim=1)           # L2 归一化\n        return z\n\n    def encode(self, x):\n        \"\"\"返回 encoder 原始特征向量（用于 linear probe）\"\"\"\n        return self.encoder(x)\n\n\n# ============================================================\n# 5. 快速测试\n# ============================================================\nif __name__ == '__main__':\n    print(\"=\" * 60)\n    print(\"测试 SmallCNN\")\n    cnn = SmallCNN(in_channels=3, feat_dim=256)\n    x = torch.randn(4, 3, 32, 32)\n    out = cnn(x)\n    print(f\"  输入: {x.shape}  ->  输出: {out.shape} (期望 [4, 256])\")\n\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试 ResNet-18 (CIFAR-10 适配)\")\n    resnet = ResNet18(in_channels=3, feat_dim=512)\n    out = resnet(x)\n    print(f\"  输入: {x.shape}  ->  输出: {out.shape} (期望 [4, 512])\")\n\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试 ProjectionHead\")\n    proj = ProjectionHead(in_dim=512, hidden_dim=512, out_dim=128)\n    h = torch.randn(4, 512)\n    z = proj(h)\n    print(f\"  输入: {h.shape}  ->  输出: {z.shape} (期望 [4, 128])\")\n\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试完整 SimCLR (resnet18)\")\n    simclr = SimCLR(encoder_name='resnet18')\n    x1 = torch.randn(4, 3, 32, 32)\n    x2 = torch.randn(4, 3, 32, 32)\n    z1 = simclr(x1)\n    z2 = simclr(x2)\n    feat = simclr.encode(x1)\n    print(f\"  z1: {z1.shape}, z2: {z2.shape}, feat: {feat.shape}\")\n    print(f\"  L2 norm of z1: {z1.norm(dim=1)[:4]} (应全为 1.0)\")\n\n    print(\"\\n\" + \"=\" * 60)\n    print(\"测试完整 SimCLR (cnn)\")\n    simclr_cnn = SimCLR(encoder_name='cnn')\n    z1 = simclr_cnn(x1)\n    feat = simclr_cnn.encode(x1)\n    print(f\"  z1: {z1.shape}, feat: {feat.shape}\")\n\n    # 统计参数量\n    print(\"\\n\" + \"=\" * 60)\n    print(\"参数量统计:\")\n    for name, model in [('SmallCNN', cnn), ('ResNet18', resnet)]:\n        params = sum(p.numel() for p in model.parameters())\n        print(f\"  {name}: {params:,} 参数\")\n\n    proj_params = sum(p.numel() for p in proj.parameters())\n    print(f\"  ProjectionHead: {proj_params:,} 参数\")\n    print(f\"  SimCLR (resnet18): {sum(p.numel() for p in simclr.parameters()):,} 参数\")\n    print(f\"  SimCLR (cnn): {sum(p.numel() for p in simclr_cnn.parameters()):,} 参数\")\n","numLines":255,"startLine":1,"totalLines":255}},"sourceToolAssistantUUID":"b74e0e04-e89a-47be-bd6d-21ed8abe03e0","userType":"external","entrypoint":"cli","cwd":"E:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main","sessionId":"5ca0762f-62dc-46ac-bae9-80edd8347491","version":"2.1.138","gitBranch":"master"}
