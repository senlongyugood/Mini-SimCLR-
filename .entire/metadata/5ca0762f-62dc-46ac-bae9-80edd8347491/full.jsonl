                    if k.startswith('encoder.')}\n    model.load_state_dict(encoder_state, strict=False)\n    return model\n","structuredPatch":[],"originalFile":null,"userModified":false},"sourceToolAssistantUUID":"abbd0b96-38a9-4017-afc0-4b3f9a2586f1","userType":"external","entrypoint":"cli","cwd":"E:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code","sessionId":"5ca0762f-62dc-46ac-bae9-80edd8347491","version":"2.1.138","gitBranch":"master"}
