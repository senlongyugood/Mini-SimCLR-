{"parentUuid":"ea3882b1-0fd5-47d5-a332-f95404dcbb42","isSidechain":false,"promptId":"553e2524-13ef-45f0-97a9-eaf83675c0cb","type":"user","message":{"role":"user","content":[{"tool_use_id":"call_00_E2aOEbhPS6FCv4KlnUcc3274","type":"tool_result","content":"1\timport torch\n2\timport torchvision\n3\timport torchvision.transforms as transforms\n4\t\n5\t\n6\tclass SimCLRTransform:\n7\t    \"\"\"对同一张 CIFAR-10 图像生成两种随机增强视图\"\"\"\n8\t\n9\t    def __init__(self, size=32):\n10\t        # 颜色抖动参数\n11\t        color_jitter = transforms.ColorJitter(\n12\t            brightness=0.8, contrast=0.8, saturation=0.8, hue=0.2\n13\t        )\n14\t\n15\t        # 单视图增强流水线\n16\t        self.transform = transforms.Compose([\n17\t            transforms.RandomResizedCrop(size, scale=(0.2, 1.0)),\n18\t            transforms.RandomHorizontalFlip(p=0.5),\n19\t            transforms.RandomApply([color_jitter], p=0.8),\n20\t            transforms.RandomGrayscale(p=0.2),\n21\t            transforms.ToTensor(),\n22\t        ])\n23\t\n24\t    def __call__(self, x):\n25\t        \"\"\"返回同一张图的两个增强视图\"\"\"\n26\t        return self.transform(x), self.transform(x)\n27\t\n28\t\n29\tdef get_cifar10_dataloader(data_dir, batch_size=64, num_workers=0, train_size=None):\n30\t    \"\"\"\n31\t    加载 CIFAR-10 训练集（不使用标签）\n32\t\n33\t    参数:\n34\t        data_dir: CIFAR-10 数据存放路径\n35\t        batch_size: 批次大小\n36\t        num_workers: 数据加载线程数\n37\t        train_size: 只取前 N 张图（用于 CPU 快速实验），None 表示全量 50000\n38\t    \"\"\"\n39\t    transform = SimCLRTransform(size=32)\n40\t\n41\t    dataset = torchvision.datasets.CIFAR10(\n42\t        root=data_dir, train=True, download=False, transform=transform\n43\t    )\n44\t\n45\t    if train_size is not None:\n46\t        dataset.data = dataset.data[:train_size]\n47\t\n48\t    loader = torch.utils.data.DataLoader(\n49\t        dataset, batch_size=batch_size, shuffle=True,\n50\t        num_workers=num_workers, drop_last=True\n51\t    )\n52\t    return loader\n53\t\n54\t\n55\tdef get_cifar10_test_dataloader(data_dir, batch_size=64, num_workers=0):\n56\t    \"\"\"加载 CIFAR-10 测试集（线性评估用，保留标签）\"\"\"\n57\t    test_transform = transforms.Compose([\n58\t        transforms.ToTensor(),\n59\t    ])\n60\t\n61\t    dataset = torchvision.datasets.CIFAR10(\n62\t        root=data_dir, train=False, download=False, transform=test_transform\n63\t    )\n64\t\n65\t    loader = torch.utils.data.DataLoader(\n66\t        dataset, batch_size=batch_size, shuffle=False,\n67\t        num_workers=num_workers\n68\t    )\n69\t    return loader\n70\t"}]},"uuid":"1c783ba8-d24d-4fe2-99dc-9fa5b07578f1","timestamp":"2026-06-27T11:35:13.114Z","toolUseResult":{"type":"text","file":{"filePath":"e:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code\\data_utils.py","content":"import torch\nimport torchvision\nimport torchvision.transforms as transforms\n\n\nclass SimCLRTransform:\n    \"\"\"对同一张 CIFAR-10 图像生成两种随机增强视图\"\"\"\n\n    def __init__(self, size=32):\n        # 颜色抖动参数\n        color_jitter = transforms.ColorJitter(\n            brightness=0.8, contrast=0.8, saturation=0.8, hue=0.2\n        )\n\n        # 单视图增强流水线\n        self.transform = transforms.Compose([\n            transforms.RandomResizedCrop(size, scale=(0.2, 1.0)),\n            transforms.RandomHorizontalFlip(p=0.5),\n            transforms.RandomApply([color_jitter], p=0.8),\n            transforms.RandomGrayscale(p=0.2),\n            transforms.ToTensor(),\n        ])\n\n    def __call__(self, x):\n        \"\"\"返回同一张图的两个增强视图\"\"\"\n        return self.transform(x), self.transform(x)\n\n\ndef get_cifar10_dataloader(data_dir, batch_size=64, num_workers=0, train_size=None):\n    \"\"\"\n    加载 CIFAR-10 训练集（不使用标签）\n\n    参数:\n        data_dir: CIFAR-10 数据存放路径\n        batch_size: 批次大小\n        num_workers: 数据加载线程数\n        train_size: 只取前 N 张图（用于 CPU 快速实验），None 表示全量 50000\n    \"\"\"\n    transform = SimCLRTransform(size=32)\n\n    dataset = torchvision.datasets.CIFAR10(\n        root=data_dir, train=True, download=False, transform=transform\n    )\n\n    if train_size is not None:\n        dataset.data = dataset.data[:train_size]\n\n    loader = torch.utils.data.DataLoader(\n        dataset, batch_size=batch_size, shuffle=True,\n        num_workers=num_workers, drop_last=True\n    )\n    return loader\n\n\ndef get_cifar10_test_dataloader(data_dir, batch_size=64, num_workers=0):\n    \"\"\"加载 CIFAR-10 测试集（线性评估用，保留标签）\"\"\"\n    test_transform = transforms.Compose([\n        transforms.ToTensor(),\n    ])\n\n    dataset = torchvision.datasets.CIFAR10(\n        root=data_dir, train=False, download=False, transform=test_transform\n    )\n\n    loader = torch.utils.data.DataLoader(\n        dataset, batch_size=batch_size, shuffle=False,\n        num_workers=num_workers\n    )\n    return loader\n","numLines":70,"startLine":1,"totalLines":70}},"sourceToolAssistantUUID":"ea3882b1-0fd5-47d5-a332-f95404dcbb42","userType":"external","entrypoint":"cli","cwd":"E:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code","sessionId":"5ca0762f-62dc-46ac-bae9-80edd8347491","version":"2.1.138","gitBranch":"master"}
