{"parentUuid":"d25bf6bb-b9c5-4eac-bce6-46e81327cced","isSidechain":false,"message":{"id":"c0c1c070-be7f-4350-af69-00ee0ba9fdaa","type":"message","role":"assistant","model":"deepseek-v4-pro","content":[{"type":"tool_use","id":"call_00_ET_4UhVd6K9T6GmeammEAIf2149","name":"Write","input":{"file_path":"e:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code\\linear_probe.py","content":"import torch\nimport torch.nn as nn\nimport torch.optim as optim\nfrom tqdm import tqdm\n\nfrom model import SimCLR\nfrom data_utils import get_cifar10_test_dataloader\n\n\nclass LinearClassifier(nn.Module):\n    \"\"\"线性分类头：冻结 encoder，只在输出的特征上训练一个线性层\"\"\"\n\n    def __init__(self, encoder, feat_dim, num_classes=10):\n        super().__init__()\n        self.encoder = encoder\n        for p in self.encoder.parameters():\n            p.requires_grad = False          # 冻结 encoder\n        self.encoder.eval()                  # 关闭 BN 的 train mode\n\n        self.classifier = nn.Linear(feat_dim, num_classes)\n\n    def forward(self, x):\n        with torch.no_grad():\n            h = self.encoder(x)              # (B, feat_dim)\n        return self.classifier(h)\n\n\ndef evaluate(model, loader, device):\n    \"\"\"评估分类准确率\"\"\"\n    model.eval()\n    correct = total = 0\n    with torch.no_grad():\n        for x, y in loader:\n            x, y = x.to(device), y.to(device)\n            logits = model(x)\n            pred = logits.argmax(dim=1)\n            correct += (pred == y).sum().item()\n            total += y.size(0)\n    return correct / total * 100\n\n\ndef linear_probe(config):\n    \"\"\"线性评估：冻结预训练 encoder，只训练一个线性分类头\n\n    这是 SimCLR 评估标准做法：\n    1. 加载预训练的 SimCLR（只用 encoder）\n    2. 冻结 encoder\n    3. 在 encoder 输出上训练一个 Linear 层\n    4. 用测试集分类准确率衡量表征质量\n    \"\"\"\n    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n    print(f\"Device: {device}\")\n\n    # ---- 加载预训练 encoder ----\n    simclr = SimCLR(\n        encoder_name=config.get('encoder', 'resnet18'),\n        proj_hidden_dim=config.get('proj_hidden_dim', 512),\n        proj_out_dim=config.get('proj_out_dim', 128),\n    ).to(device)\n\n    checkpoint = torch.load(config['checkpoint_path'], map_location=device)\n    simclr.load_state_dict(checkpoint['model_state_dict'])\n    print(f\"Loaded checkpoint: epoch {checkpoint['epoch']}, loss {checkpoint['loss']:.4f}\")\n\n    encoder = simclr.encoder\n    feat_dim = simclr.encoder.feat_dim\n\n    # ---- 冻结 encoder + 线性分类头 ----\n    model = LinearClassifier(encoder, feat_dim, num_classes=10).to(device)\n\n    # ---- 数据 ----\n    from data_utils import get_cifar10_dataloader\n    train_loader = get_cifar10_dataloader(\n        data_dir=config['data_dir'],\n        batch_size=config['batch_size'],\n        num_workers=config.get('num_workers', 0),\n    )\n    test_loader = get_cifar10_test_dataloader(\n        data_dir=config['data_dir'],\n        batch_size=config['batch_size'],\n        num_workers=config.get('num_workers', 0),\n    )\n\n    # ---- 优化器（只优化 Linear 层） ----\n    optimizer = optim.SGD(\n        model.classifier.parameters(),\n        lr=config.get('lr', 0.1),\n        momentum=0.9,\n        weight_decay=config.get('weight_decay', 1e-4),\n    )\n\n    criterion = nn.CrossEntropyLoss()\n\n    # ---- 训练 ----\n    best_acc = 0.0\n    for epoch in range(1, config['epochs'] + 1):\n        model.train()\n        total_loss = 0.0\n\n        pbar = tqdm(train_loader, desc=f\"Linear probe epoch {epoch}/{config['epochs']}\")\n        for (x1, _), y in pbar:\n            x1, y = x1.to(device), y.to(device)\n\n            logits = model(x1)\n            loss = criterion(logits, y)\n\n            optimizer.zero_grad()\n            loss.backward()\n            optimizer.step()\n\n            total_loss += loss.item()\n            pbar.set_postfix(loss=f\"{loss.item():.4f}\")\n\n        train_acc = evaluate(model, train_loader, device)\n        test_acc = evaluate(model, test_loader, device)\n        avg_loss = total_loss / len(train_loader)\n\n        print(f\"Epoch {epoch:3d}  loss={avg_loss:.4f}  \"\n              f\"train_acc={train_acc:.2f}%  test_acc={test_acc:.2f}%\")\n\n        if test_acc > best_acc:\n            best_acc = test_acc\n\n    print(f\"\\nBest test accuracy: {best_acc:.2f}%\")\n    return best_acc\n\n\nif __name__ == '__main__':\n    config = {\n        'data_dir': '../data',\n        'checkpoint_path': '../checkpoints/simclr_best.pth',\n        'batch_size': 256,\n        'epochs': 50,\n        'encoder': 'resnet18',\n        'proj_hidden_dim': 512,\n        'proj_out_dim': 128,\n        'lr': 0.1,\n        'weight_decay': 1e-4,\n        'num_workers': 0,\n    }\n    linear_probe(config)\n"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":601,"cache_creation_input_tokens":0,"cache_read_input_tokens":35456,"output_tokens":1316,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"type":"assistant","uuid":"452c5466-fb11-40ab-8872-5541fbb73277","timestamp":"2026-06-27T11:37:23.355Z","userType":"external","entrypoint":"cli","cwd":"E:\\program_prject\\vscode_python_project\\论文复现\\mini-simclr-assignment-main\\mini-simclr-assignment-main\\code","sessionId":"5ca0762f-62dc-46ac-bae9-80edd8347491","version":"2.1.138","gitBranch":"master"}
